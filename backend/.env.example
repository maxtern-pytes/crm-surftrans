# SurfTrans AI Freight Broker Platform
# Environment Configuration

# ============================================
# Server Configuration
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# Options: 'sqlite' (development) or 'postgres' (production)
DB_TYPE=sqlite

# PostgreSQL (for production)
DATABASE_URL=postgresql://user:password@localhost:5432/surftrans

# ============================================
# Redis Configuration
# ============================================
# Optional - improves performance with caching
REDIS_URL=redis://localhost:6379

# ============================================
# Ollama AI Configuration
# ============================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@surftrans.com

# ============================================
# JWT Secret
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# Scraping Configuration
# ============================================
SCRAPER_DELAY=2000
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT=10000

# ============================================
# AI Task Assignment Thresholds
# ============================================
# Create call task for deals over this amount
CALL_TASK_THRESHOLD=5000

# Auto-approve deals under this amount
AUTO_APPROVE_THRESHOLD=2000

# Commission cap removal threshold
COMMISSION_CAP_REMOVAL_THRESHOLD=10000

# ============================================
# Cache TTL (in seconds)
# ============================================
CACHE_AI_RESPONSE=600
CACHE_MARKET_DATA=3600
CACHE_SCRAPED_DATA=1800

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# Production Settings
# ============================================
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://app.surftrans.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Feature Flags
# ============================================
ENABLE_REDIS_CACHE=true
ENABLE_WEB_SCRAPING=true
ENABLE_EMAIL_SENDING=false
ENABLE_AI_TASK_ASSIGNMENT=true
ENABLE_MARKET_TRENDS=true
